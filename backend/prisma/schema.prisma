generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  password     String
  firstName    String
  lastName     String
  role         String      @default("EMPLOYEE")
  hourlyRate   Float       @default(0)
  phone        String?
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  shifts             Shift[]
  coverShifts        Shift[]          @relation("ShiftCoverCarers")
  requestedTrades    ShiftTrade[]     @relation("TradeRequester")
  targetedTrades     ShiftTrade[]     @relation("TradeTarget")
  timeOffRequests    TimeOffRequest[]
  clockRecords       ClockRecord[]
  notifications      Notification[]
  preferredBy        ServiceUser[]    @relation("PreferredCaregivers")
  callLogs           CallLog[]
  medAdministrations MedAdministration[]
  pushSubscriptions  PushSubscription[]
  familyLinks        FamilyLink[]
}

model Site {
  id        String        @id @default(cuid())
  name      String        @unique
  color     String        @default("#3b82f6")
  createdAt DateTime      @default(now())

  serviceUsers ServiceUser[]
}

model ServiceUser {
  id                       String   @id @default(cuid())
  firstName                String
  lastName                 String
  dateOfBirth              DateTime
  siteId                   String?
  nhsNumber                String?
  address                  String?
  postcode                 String?
  phone                    String?
  email                    String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  gpName                   String?
  gpPractice               String?
  gpPhone                  String?
  gpAddress                String?
  pharmacyName             String?
  pharmacyPhone            String?
  pharmacyAddress          String?
  needsMedication          Boolean  @default(false)
  needsMobility            Boolean  @default(false)
  needsPersonalCare        Boolean  @default(false)
  careNotes                String?
  visitDuration            Int      @default(30)
  visits                   String   @default("[]") // JSON array of { type, duration }
  active                   Boolean  @default(true)
  status                   String   @default("ACTIVE") // ACTIVE, ON_HOLD, HOSPITALISED, DISCHARGED, DECEASED
  statusUpdatedAt          DateTime @default(now()) // when status last changed — so calendar badges only apply from this date onwards
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  site                Site?   @relation(fields: [siteId], references: [id])
  preferredCaregivers User[]  @relation("PreferredCaregivers")
  shifts              Shift[]
  callLogs            CallLog[]
  medications         Medication[]
  medAdministrations  MedAdministration[]
  carePlan            CarePlan?
  servicePlan         PersonalServicePlan?
  familyLinks         FamilyLink[]
  likesDislikes       LikesDislikes?
}

// Links a family-member User account to the service user(s) they're allowed
// to view read-only details for, via the separate family-portal app.
model FamilyLink {
  id            String   @id @default(cuid())
  userId        String
  serviceUserId String
  relation      String?
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceUser ServiceUser @relation(fields: [serviceUserId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceUserId])
}

model PersonalServicePlan {
  id            String   @id @default(cuid())
  serviceUserId String   @unique
  data          String   @default("{}") // JSON: all assessment field values keyed by item id
  updatedById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  serviceUser ServiceUser @relation(fields: [serviceUserId], references: [id], onDelete: Cascade)
}

model CarePlan {
  id            String    @id @default(cuid())
  serviceUserId String    @unique
  // Weekly visit profile — JSON: { Monday: { morning, lunch, tea, bed }, ... }
  schedule        String    @default("{}")
  // Tasks required at each visit
  tasksMorning    String?
  tasksLunch      String?
  tasksTea        String?
  tasksBed        String?
  numberOfCarers  String?
  carePackageInfo String?
  otherNotes      String?
  reviewDate      DateTime?
  // Legacy assessment-style fields (retained; now covered by the Personal Service Plan)
  summary       String?
  personalCare  String?
  mobility      String?
  nutrition     String?
  continence    String?
  medication    String?
  communication String?
  mentalHealth  String?
  social        String?
  dailyRoutine  String?
  risks         String?
  goals         String?
  updatedById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  serviceUser ServiceUser @relation(fields: [serviceUserId], references: [id], onDelete: Cascade)
}

model LikesDislikes {
  id              String   @id @default(cuid())
  serviceUserId   String   @unique
  likes           String?
  dislikes        String?
  lifeHistory     String? // "A little of my life history"
  health          String? // "My health"
  whatPeopleLike  String? // "What might people like about me?"
  relationships   String?
  goodDay         String? // "What makes a good day for me"
  badDay          String? // "What makes a bad day for me"
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  serviceUser ServiceUser @relation(fields: [serviceUserId], references: [id], onDelete: Cascade)
}

model Medication {
  id            String    @id @default(cuid())
  serviceUserId String
  name          String
  dose          String?
  route         String?
  instructions  String?
  times         String    @default("[]") // JSON array of "HH:MM" dose times
  // JSON array of { view: 'front'|'back'|'faceFront'|'faceSide', x, y } body-map
  // points (x/y as % of the diagram) — where a cream/lotion should be applied.
  applicationSites String  @default("[]")
  startDate     DateTime?
  endDate       DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  serviceUser     ServiceUser         @relation(fields: [serviceUserId], references: [id], onDelete: Cascade)
  administrations MedAdministration[]
}

model MedAdministration {
  id            String   @id @default(cuid())
  medicationId  String
  serviceUserId String
  userId        String?
  scheduledFor  DateTime
  status        String   // GIVEN, REFUSED, MISSED, NOT_NEEDED, SELF_ADMIN
  note          String?
  recordedAt    DateTime @default(now())

  medication  Medication  @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  serviceUser ServiceUser @relation(fields: [serviceUserId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([medicationId, scheduledFor])
}

model Shift {
  id            String      @id @default(cuid())
  userId        String?
  serviceUserId String?
  seriesId      String?
  date          DateTime
  startTime     String
  endTime       String
  visitName     String?
  cover         Int         @default(1)
  role          String?
  notes         String?
  status        String      @default("SCHEDULED")
  // Defaults true at the DB level so pre-existing shifts stay visible to
  // carers; newly created shifts are explicitly set to false by the
  // controller until a manager publishes them.
  published     Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverCarers  User[]       @relation("ShiftCoverCarers")
  serviceUser  ServiceUser? @relation(fields: [serviceUserId], references: [id])
  tradeOffers  ShiftTrade[] @relation("OriginalShift")
  tradeTargets ShiftTrade[] @relation("TargetShift")
  clockRecords ClockRecord[]
  callLogs     CallLog[]
}

model CallLog {
  id            String   @id @default(cuid())
  shiftId       String?
  serviceUserId String
  userId        String?
  note          String
  createdAt     DateTime @default(now())

  shift       Shift?      @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  serviceUser ServiceUser @relation(fields: [serviceUserId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ShiftTrade {
  id            String   @id @default(cuid())
  requesterId   String
  targetUserId  String?
  shiftId       String
  targetShiftId String?
  message       String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requester   User   @relation("TradeRequester", fields: [requesterId], references: [id])
  targetUser  User?  @relation("TradeTarget", fields: [targetUserId], references: [id])
  shift       Shift  @relation("OriginalShift", fields: [shiftId], references: [id])
  targetShift Shift? @relation("TargetShift", fields: [targetShiftId], references: [id])
}

model TimeOffRequest {
  id        String   @id @default(cuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  type      String
  reason    String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClockRecord {
  id        String    @id @default(cuid())
  userId    String
  shiftId   String?
  clockIn   DateTime
  clockOut  DateTime?
  createdAt DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift Shift? @relation(fields: [shiftId], references: [id])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tracks which shift-reminder pushes have already been sent so the
// reminder poller (which runs every minute) never double-sends.
model ShiftReminder {
  id      String   @id @default(cuid())
  shiftId String
  userId  String
  type    String // "BEFORE" (30 mins before) | "START" (at call start)
  sentAt  DateTime @default(now())

  @@unique([shiftId, userId, type])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// One-time link sent to a newly-created staff member so they can set
// their own password instead of a manager choosing one for them.
model PasswordSetupToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
